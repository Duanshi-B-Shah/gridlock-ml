# OpenF1 API
OPENF1_BASE_URL=https://api.openf1.org/v1

# Paths (defaults work out of the box)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
MODELS_DIR=models
PLOTS_DIR=plots

# Model
MODEL_FILENAME=xgb_f1_model.joblib

# Feature engineering
ROLLING_WINDOW_SHORT=3
ROLLING_WINDOW_LONG=5

# Logging
LOG_LEVEL=INFO

# MLflow
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=f1-race-predictor
MLFLOW_MODEL_REGISTRY_NAME=f1-position-predictor

# Phase 1 Data Sources (all from OpenF1 API — no additional keys needed):
# - /weather: track temp, air temp, humidity, wind speed, rainfall
# - /stints: tire compounds, pit stop counts, stint lengths
# - /sessions + /position: qualifying session positions
